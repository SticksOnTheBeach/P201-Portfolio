{
  "name": "portfolio",
  "description": "Portfolio BUT Informatique",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --mode ssr",
    "build.server": "qwik check-client src dist && vite build -c adapters/vercel-edge/vite.config.ts",
    "deploy": "vercel deploy",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "lint": "echo 'Linting ignoré pour le moment'",
    "preview": "qwik build preview && vite preview --open"
  },
  "devDependencies": {
    "@builder.io/qwik": "^1.5.5",
    "@builder.io/qwik-city": "^1.5.5",
    "@types/node": "^20.11.5",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.57.1",
    "ignore": "^7.0.5",
    "postcss": "^8.4.33",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "undici": "^6.3.0",
    "vercel": "^29.1.1",
    "vite": "^5.0.12",
    "vite-tsconfig-paths": "^4.3.1"
  }
}
